@using System.Linq
@model IEnumerable<WineShop.Models.Product>

@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container py-4">
    <h2 class="mb-4">Shopping Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Please add items to cart.</div>
        <a asp-controller="Home" asp-action="ShopSite" class="btn btn-outline-primary">Continue Shopping</a>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="row align-items-center">
                                <div class="col-md-2 text-center">
                                    <img src="@WC.ImageProductPath@item.Image" class="img-fluid rounded" style="max-height:100px;" />
                                </div>
                                <div class="col-md-7">
                                    <h5 class="mb-1">@item.Name</h5>
                                    <p class="mb-0 text-muted">@item.Description</p>
                                </div>
                                <div class="col-md-1 text-md-end">
                                    <strong>@item.Price.ToString("0.00") zł</strong>
                                </div>
                                <div class="col-md-2 text-md-end">
                                    <form asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-outline-danger">Remove</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a asp-controller="Home" asp-action="ShopSite" class="btn btn-outline-primary">Continue Shopping</a>

            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Continue</button>
            </form>
        </div>
    }
</div>