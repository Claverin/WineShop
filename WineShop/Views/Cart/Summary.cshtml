@model WineShop.Models.ViewModels.CheckoutVM

@{
    ViewData["Title"] = "Order Summary";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Order Summary</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Cart</a>
    </div>

    <form asp-action="Summary" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h4 class="mb-3">Customer Details</h4>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Street" class="form-label"></label>
                            <input asp-for="Street" class="form-control" />
                            <span asp-validation-for="Street" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="PostalCode" class="form-label"></label>
                                <input asp-for="PostalCode" class="form-control" />
                                <span asp-validation-for="PostalCode" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mb-3">
                                <label asp-for="City" class="form-label"></label>
                                <input asp-for="City" class="form-control" />
                                <span asp-validation-for="City" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PaymentMethodId" class="form-label"></label>
                            <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethods" class="form-select"></select>
                            <span asp-validation-for="PaymentMethodId" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h4 class="mb-3">Summary</h4>

                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex justify-content-between border-bottom py-2">
                                <div>
                                    <div>@item.Name</div>
                                    <small class="text-muted">@item.Quantity x @item.Price.ToString("0.00") zł</small>
                                </div>
                                <strong>@item.LineTotal.ToString("0.00") zł</strong>
                            </div>
                        }

                        <div class="d-flex justify-content-between pt-3">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold">@Model.TotalAmount.ToString("0.00") zł</span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mt-4">Place Order</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
