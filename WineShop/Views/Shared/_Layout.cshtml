@using Microsoft.AspNetCore.Http
@using WineShop.Models
@using WineShop.Utility
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WineShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WineShop.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/fontawesome/css/all.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WineShop</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole(WC.AdminRole))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="ShopSite">Shop</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Orders" asp-action="Index">Manage Orders</a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="productDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Product
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="productDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index">Product</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Manufacturer" asp-action="Index">Manufacturer</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ProductType" asp-action="Index">Product Type</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="shippingDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Shipping
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="shippingDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Shipment" asp-action="Index">Shipment Overview</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="OrderStatus" asp-action="Index">Order Status</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="PaymentMethod" asp-action="Index">Payment Method</a></li>
                                </ul>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Register">Create Admin User</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="ShopSite">Shop</a>
                            </li>

                            @if (User.IsInRole(WC.CustomerRole))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Shipment" asp-action="Index">My Orders</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            @{
                                var cart = HttpContextAccessor.HttpContext?.Session.Get<List<ShoppingCart>>(WC.SessionCart);
                                var count = cart?.Sum(x => x.Quantity) ?? 0;
                            }

                            <a asp-action="Index" asp-controller="Cart" class="nav-link">
                                <i class="fas fa-shopping-cart"></i> &nbsp; (@count)
                            </a>
                        </li>

                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        <div class="container text-center text-white">
            @RenderBody()
        </div>
    </main>

    <footer class="footer text-muted">
        <div class="container pt-4 pb-3 text-center">
            &copy; 2026 - WineShop - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>