@model WineShop.Models.ViewModels.AdminOrderDetailsVM

@{
    ViewData["Title"] = $"Manage Order #{Model.OrderId}";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Manage Order #@Model.OrderId</h2>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to Orders</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Customer</h4>

                    <div class="mb-2"><strong>Name:</strong> @Model.CustomerName</div>
                    <div class="mb-2"><strong>Email:</strong> @Model.CustomerEmail</div>
                    <div class="mb-2"><strong>Phone:</strong> @Model.CustomerPhoneNumber</div>
                    <div class="mb-2"><strong>Address:</strong> @Model.Street, @Model.PostalCode @Model.City</div>
                    <div class="mb-2"><strong>Created:</strong> @Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    <div class="mb-2"><strong>Payment:</strong> @Model.PaymentMethodName</div>
                    <div class="mb-0"><strong>Total:</strong> @Model.TotalAmount.ToString("0.00") zł</div>
                </div>
            </div>

            <div class="card shadow-sm mt-4">
                <div class="card-body">
                    <h4 class="mb-3">Items</h4>

                    <div class="table-responsive">
                        <table class="table table-bordered table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Unit Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td>@item.UnitPrice.ToString("0.00") zł</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.LineTotal.ToString("0.00") zł</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Order & Shipping</h4>

                    <form asp-action="Update" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="OrderId" type="hidden" />

                        <div class="mb-3">
                            <label asp-for="OrderStatusId" class="form-label"></label>
                            <select asp-for="OrderStatusId" asp-items="Model.Statuses" class="form-select"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Carrier" class="form-label"></label>
                            <input asp-for="Carrier" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShippingMethod" class="form-label"></label>
                            <input asp-for="ShippingMethod" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="TrackingNumber" class="form-label"></label>
                            <input asp-for="TrackingNumber" class="form-control" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ShippedDate" class="form-label"></label>
                                <input asp-for="ShippedDate" type="date" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DeliveredDate" class="form-label"></label>
                                <input asp-for="DeliveredDate" type="date" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShippingNotes" class="form-label"></label>
                            <textarea asp-for="ShippingNotes" class="form-control" rows="4"></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Save Changes</button>
                    </form>

                    <hr />

                    <div class="mb-2"><strong>Current status:</strong> @Model.CurrentStatusName</div>
                    <div class="mb-2"><strong>Carrier:</strong> @(string.IsNullOrWhiteSpace(Model.Carrier) ? "-" : Model.Carrier)</div>
                    <div class="mb-2"><strong>Tracking:</strong> @(string.IsNullOrWhiteSpace(Model.TrackingNumber) ? "-" : Model.TrackingNumber)</div>
                    <div class="mb-2"><strong>Shipped:</strong> @(Model.ShippedDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                    <div class="mb-0"><strong>Delivered:</strong> @(Model.DeliveredDate?.ToString("yyyy-MM-dd") ?? "-")</div>
                </div>
            </div>
        </div>
    </div>
</div>