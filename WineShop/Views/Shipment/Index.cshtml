@using WineShop.Utility
@model IEnumerable<WineShop.Models.ViewModels.ShipmentListItemVM>

@{
    ViewData["Title"] = User.IsInRole(WC.AdminRole) ? "Shipment Overview" : "My Orders";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">
            No orders found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>Order</th>
                        @if (User.IsInRole(WC.AdminRole))
                        {
                            <th>Customer</th>
                        }
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Carrier</th>
                        <th>Method</th>
                        <th>Tracking</th>
                        <th>Shipped</th>
                        <th>Delivered</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.OrderId</td>
                            @if (User.IsInRole(WC.AdminRole))
                            {
                                <td>@item.CustomerEmail</td>
                            }
                            <td>@item.StatusName</td>
                            <td>@item.PaymentMethodName</td>
                            <td>@(string.IsNullOrWhiteSpace(item.Carrier) ? "-" : item.Carrier)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ShippingMethod) ? "-" : item.ShippingMethod)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.TrackingNumber) ? "-" : item.TrackingNumber)</td>
                            <td>@(item.ShippedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>@(item.DeliveredDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>@item.TotalAmount.ToString("0.00") zł</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>