@model IEnumerable<WineShop.Models.ViewModels.ShipmentListItemVM>

@{
    ViewData["Title"] = User.IsInRole(WC.AdminRole) ? "Orders and Shipments" : "My Orders";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">@ViewData["Title"]</h2>

        @if (User.IsInRole(WC.AdminRole))
        {
            <a asp-action="Create" class="btn btn-primary">Create Shipment</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info mb-0">
            No orders found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead>
                    <tr>
                        <th>Order</th>
                        @if (User.IsInRole(WC.AdminRole))
                        {
                            <th>Customer</th>
                        }
                        <th>Status</th>
                        <th>Payment</th>
                        <th>Total</th>
                        <th>Created</th>
                        <th>Sent</th>
                        <th>Delivered</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.OrderId</td>
                            @if (User.IsInRole(WC.AdminRole))
                            {
                                <td>@item.CustomerEmail</td>
                            }
                            <td>@item.StatusName</td>
                            <td>@item.PaymentMethodName</td>
                            <td>@item.TotalAmount.ToString("0.00") zł</td>
                            <td>@item.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(item.SendDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td>@(item.DeliverDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
